{
  "_comment": "This template shows all available parameters that can be controlled in the Step Functions pipeline",
  "_usage": "Set stage values to true to execute them, or false to skip them. If a stage is not specified, it defaults to being executed.",
  "notifications_enabled": true,    // Set to false to disable all email notifications
  "stages": {
    "crawler_arm_build": false,           // Build ARM-based crawler Docker image
    "cluster_create": false,              // Create EKS cluster infrastructure
    "crawl_wpapi_hidden": false,          // Crawl WordPress API for hidden content (dataset_type: h)
    "crawl_wpapi_non_hidden": false,      // Crawl WordPress API for non-hidden content (dataset_type: nh)
    "crawl_sitemap_hidden": false,        // Crawl sitemap URLs for hidden content (dataset_type: h)
    "crawl_sitemap_non_hidden": false,    // Crawl sitemap URLs for non-hidden content (dataset_type: nh)
    "delta_upsert": false,                // Perform Delta Lake upsert for WordPress API data
    "generate_sitemap_seeds": false,      // Generate seed files from sitemaps for URL crawling
    "crawl_urls_hidden": false,           // Crawl individual URLs from sitemaps (hidden content)
    "crawl_urls_non_hidden": false,       // Crawl individual URLs from sitemaps (non-hidden content)
    "sitemaps_delta_upsert": false,       // Perform Delta Lake upsert for sitemap crawl data
    "cluster_destroy": false,             // Destroy EKS cluster infrastructure
    "schedule_s3_deletion": false         // Schedule S3 folder deletion after cluster destruction
  },
  "s3_deletion_config": {                 // Configuration for S3 deletion (only used if schedule_s3_deletion is true)
    "folders": [                          // List of S3 folders to delete (paths relative to s3://{bucket}/{dataset}/)
      // "update/results/crawl-",         // Example: deletes s3://{bucket}/{dataset}/update/results/crawl-*
      // "temp/",                          // Example: deletes s3://{bucket}/{dataset}/temp/
      // "scratch/processing/"             // Example: deletes s3://{bucket}/{dataset}/scratch/processing/
    ],
    "deletion_delay_seconds": 259200,     // Seconds to wait before deletion (default: 259200 = 72 hours)
    "check_delay_seconds": 28800          // Seconds to wait before checking deletion (default: 28800 = 8 hours)
    // Common time values in seconds:
    // 1 hour = 3600
    // 24 hours = 86400  
    // 7 days = 604800
    // 30 days = 2592000
  }
}