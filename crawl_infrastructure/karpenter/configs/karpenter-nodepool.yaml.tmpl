apiVersion: karpenter.sh/v1
kind: NodePool
metadata:
  name: ${name}
spec:
  template:
    spec:
        disruption:
          expireAfter: 10000s
          consolidationPolicy: WhenEmpty
          consolidateAfter: 10s
        nodeClassRef:
          group: karpenter.k8s.aws
          kind: EC2NodeClass
          name: default
        requirements:
          - key: "karpenter.sh/capacity-type"
            operator: In
            values: ["spot"]
          - key: karpenter.k8s.aws/instance-category
            operator: In
            values: ["t", "c", "r", "m", "x"]
          - key: karpenter.k8s.aws/instance-size
            operator: In
            values: ["small", "medium", "large", "xlarge"]
        #  - key: "karpenter.k8s.aws/instance-memory"
        #    operator: Lt
        #    values: ["2500"]
        #  - key: "node.kubernetes.io/instance-type"
        #    operator: In
        #    values: ["t4g.small","c7g.medium","c6gd.medium","c6g.medium","c6gn.medium","m7g.medium", "c7gd.medium", "m7gd.medium", "r6g.medium", "c7gn.medium", "r7g.medium", "m6g.medium", "r7gd.medium"]
          - key: "kubernetes.io/arch"
            operator: In
            values: ["arm64"]
          - key: kubernetes.io/os
            operator: In
            values: ["linux"]
%{ if taints != null ~}
        taints:
        - key: ${taints.key}
          value: ${taints.value}
          effect: ${taints.effect}
%{ endif ~}
%{ if labels != null ~}
        labels:
%{ for k, v in labels ~}
          ${k}: ${v}
%{ endfor ~}
%{ endif ~}
  disruption:
    expireAfter: 10000s
    consolidationPolicy: WhenEmpty
    consolidateAfter: 10s