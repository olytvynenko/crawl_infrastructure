apiVersion: karpenter.k8s.aws/v1beta1
kind: EC2NodeClass
metadata:
  name: default
spec:
  subnetSelector:
    karpenter.sh/discovery: ${cluster_name}
  securityGroupSelector:
    karpenter.sh/discovery: ${cluster_name}
  amiFamily: AL2
  amiSelectorTerms:
      - id: ami-04d00324ebf262399
      - id: ami-03513159c48355642
  blockDeviceMappings:
  - deviceName: /dev/sda1
    rootVolume: true
    ebs:
      volumeSize: 20Gi
      volumeType: gp3
      encrypted: false
  tags:
    Name: ${cluster_name}-node
    created-by: "karpneter"
    karpenter.sh/discovery: ${cluster_name}