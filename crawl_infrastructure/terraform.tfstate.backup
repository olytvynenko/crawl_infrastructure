            "id": "2384140009",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"pricing:GetProducts\",\n        \"ec2:DescribeSubnets\",\n        \"ec2:DescribeSpotPriceHistory\",\n        \"ec2:DescribeSecurityGroups\",\n        \"ec2:DescribeLaunchTemplates\",\n        \"ec2:DescribeInstances\",\n        \"ec2:DescribeInstanceTypes\",\n        \"ec2:DescribeInstanceTypeOfferings\",\n        \"ec2:DescribeImages\",\n        \"ec2:DescribeAvailabilityZones\",\n        \"ec2:CreateTags\",\n        \"ec2:CreateLaunchTemplate\",\n        \"ec2:CreateFleet\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:TerminateInstances\",\n        \"ec2:DeleteLaunchTemplate\"\n      ],\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"ec2:ResourceTag/karpenter.sh/discovery\": \"linxact-nv\"\n        }\n      }\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"ec2:RunInstances\",\n      \"Resource\": \"arn:aws:ec2:*:411623750878:launch-template/*\",\n      \"Condition\": {\n        \"StringEquals\": {\n          \"ec2:ResourceTag/karpenter.sh/discovery\": \"linxact-nv\"\n        }\n      }\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"ec2:RunInstances\",\n      \"Resource\": [\n        \"arn:aws:ec2:*::snapshot/*\",\n        \"arn:aws:ec2:*::image/*\",\n        \"arn:aws:ec2:*:411623750878:volume/*\",\n        \"arn:aws:ec2:*:411623750878:subnet/*\",\n        \"arn:aws:ec2:*:411623750878:spot-instances-request/*\",\n        \"arn:aws:ec2:*:411623750878:security-group/*\",\n        \"arn:aws:ec2:*:411623750878:network-interface/*\",\n        \"arn:aws:ec2:*:411623750878:instance/*\"\n      ]\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"ssm:GetParameter\",\n      \"Resource\": \"arn:aws:ssm:*:*:parameter/aws/service/*\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"eks:DescribeCluster\",\n      \"Resource\": \"arn:aws:eks:*:411623750878:cluster/linxact-nv\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:PassRole\",\n      \"Resource\": \"arn:aws:iam::411623750878:role/Karpenter-linxact-nv-20240124181340607500000001\"\n    },\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"sqs:ReceiveMessage\",\n        \"sqs:GetQueueUrl\",\n        \"sqs:GetQueueAttributes\",\n        \"sqs:DeleteMessage\"\n      ],\n      \"Resource\": \"arn:aws:sqs:us-east-1:411623750878:Karpenter-linxact-nv\"\n    }\n  ]\n}",
